# Eazo Private Key to decrypt the user session token on the server
EAZO_PRIVATE_KEY=your_eazo_private_key_here

# Eazo app ID. Read by RootLayout and passed into <EazoProvider> as a prop.
EAZO_APP_ID=your_eazo_app_id_here

# PostgreSQL connection string (used by Drizzle ORM)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/myapp

# Shared secret Vercel Cron uses to authenticate scheduled invocations of
# `/api/notifications/cron/daily-digest`. Generate any high-entropy string
# (e.g. `openssl rand -hex 32`) and set it both here and in Vercel's project
# env. Vercel automatically injects `Authorization: Bearer ${CRON_SECRET}`
# when firing crons declared in `vercel.json`.
CRON_SECRET=replace_with_a_long_random_string
