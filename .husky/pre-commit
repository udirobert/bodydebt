#!/bin/sh

# Pre-commit hook for Body Debt
# 1. Refuse to commit .env / .env.local
# 2. Scan for accidental secret commits
# 3. Run lint-staged for code quality

echo "🔒 Running secret scan..."

# Define patterns to check for common secrets in staged files.
# These catch private keys, API keys, tokens, passwords, seed phrases,
# and database URLs with embedded credentials.
SECRET_PATTERNS=(
  # PEM/OpenSSH keys
  "-----BEGIN (RSA |OPENSSH |PRIVATE )?KEY-----"

  # Generic API keys / tokens / secrets with values
  "[A-Za-z0-9_]+_API_KEY=[A-Za-z0-9_\\-\\.]{16,}"
  "[A-Za-z0-9_]+_TOKEN=[A-Za-z0-9_\\-\\.]{16,}"
  "[A-Za-z0-9_]+_SECRET=[A-Za-z0-9_\\-\\.]{16,}"
  "EMAIL_SERVER_PASSWORD=[A-Za-z0-9_\\-\\.]{8,}"

  # Private keys and seed phrases
  "[A-Za-z0-9_]+_PRIVATE_KEY=(0x)?[a-fA-F0-9]{64,}"
  "[A-Za-z0-9_]+_SEED_PHRASE=[A-Za-z]+( [A-Za-z]+){11,}"

  # Common provider-specific credentials
  "AIza[0-9A-Za-z\\-_]{35}"
  "sk-[a-zA-Z0-9]{20,}"
  "sk_[a-zA-Z0-9]{20,}"
  "ghp_[a-zA-Z0-9]{36}"
  "hf_[a-zA-Z0-9]{20,}"
  "KGAT_[a-zA-Z0-9]{20,}"
  "re_[a-zA-Z0-9]{20,}"

  # Eazo / database credentials
  "EAZO_PRIVATE_KEY=[a-fA-F0-9]{64}"
  "DATABASE_URL=.*:.*@"
)

# All staged files (excluding deletions)
ALL_STAGED=$(git diff --cached --name-only --diff-filter=ACM || true)

# Explicitly block committing .env and .env.local even if they somehow become staged.
for file in $ALL_STAGED; do
  if [ "$file" = ".env" ] || [ "$file" = ".env.local" ]; then
    echo "🛑 Commit aborted: refusing to commit $file. Move secrets to .env.local and keep it gitignored."
    exit 1
  fi
done

# Files to scan (exclude .husky dir, other .env.* files, and common binary/lock files)
SCAN_FILES=$(echo "$ALL_STAGED" | grep -vE '^\.husky/|\.env\.|\.png$|\.jpg$|\.jpeg$|\.gif$|\.svg$|\.webp$|\.ico$|\.lock$' || true)

if [ -n "$SCAN_FILES" ]; then
  FOUND_SECRETS=0
  for file in $SCAN_FILES; do
    if [ -f "$file" ]; then
      for pattern in "${SECRET_PATTERNS[@]}"; do
        if grep -qE "$pattern" "$file" 2>/dev/null; then
          echo "❌ Potential secret detected in $file matching pattern: $pattern"
          FOUND_SECRETS=1
        fi
      done
    fi
  done

  if [ $FOUND_SECRETS -eq 1 ]; then
    echo "🛑 Commit aborted: Please remove secrets before committing. If this is a false positive, you can bypass with --no-verify (not recommended)."
    exit 1
  fi
  echo "✅ No secrets detected."
fi

echo "🧹 Running lint-staged..."
# Execute lint-staged (which runs 'bun run lint' and 'tsc --noEmit' on staged files)
npx lint-staged

# If lint-staged fails, abort the commit
if [ $? -ne 0 ]; then
  echo "🛑 Commit aborted: Linting or type checking failed."
  exit 1
fi

echo "✅ Pre-commit checks passed!"
